generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Prospect {
  id         String   @id @default(cuid())
  siren      String   @unique
  name       String
  activity   String?
  city       String?
  postal     String?
  email      String?
  phone      String?
  website    String?
  address    String?
  hasWebsite Boolean  @default(false)
  status     String   @default("new")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}